<script is:inline>
function showTab(i) {
  document.querySelectorAll('.uc-tab').forEach((t,j)=>t.classList.toggle('active',j===i));
  document.querySelectorAll('.uc-content').forEach((c,j)=>{
    c.classList.toggle('active',j===i);
    c.style.display = j===i ? '' : 'none';
  });
}
document.querySelectorAll('.uc-content').forEach((c,i)=>{ if(!c.classList.contains('active')) c.style.display='none'; });

function toggleFaq(btn) {
  const item = btn.closest('.faq-item');
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));
  if(!isOpen) item.classList.add('open');
}

function filterFaq(cat) {
  document.querySelectorAll('.faq-cat').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  document.querySelectorAll('.faq-item').forEach(item => {
    if(cat === 'all' || item.dataset.cat === cat) {
      item.classList.remove('hidden');
    } else {
      item.classList.add('hidden');
      item.classList.remove('open');
    }
  });
}

const io = new IntersectionObserver((es)=>es.forEach((e,i)=>{ if(e.isIntersecting) setTimeout(()=>e.target.classList.add('in'),i*55); }),{threshold:.07,rootMargin:'0px 0px -28px 0px'});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

window.addEventListener('scroll',()=>{ document.querySelector('nav').style.boxShadow = window.scrollY>30?'0 4px 24px rgba(0,0,0,.25)':'none'; });
</script>

<div class="deck-overlay" id="ovMun"><button class="deck-close" onclick="closeDeck('mun')">✕</button><iframe id="ifMun" title="Presentación Clientes"></iframe></div>
<div class="deck-overlay" id="ovInv"><button class="deck-close" onclick="closeDeck('inv')">✕</button><iframe id="ifInv" title="Presentación Inversionistas"></iframe></div>
<div class="login-gate" id="loginGate"><div class="login-card">
<div class="login-logo"><span class="wm">Mun<i>IA</i></span></div>
<div class="login-sub" id="loginSub">Acceso · Presentación</div>
<div class="login-field"><label>Usuario</label><input id="luser" type="email" autocomplete="username" placeholder="correo@altkimia.com"></div>
<div class="login-field"><label>Contraseña</label><input id="lpass" type="password" autocomplete="current-password" placeholder="********" onkeydown="if(event.key==='Enter')tryLogin()"></div>
<button class="login-btn" onclick="tryLogin()">Ingresar</button>
<div class="login-err" id="lerr"></div>
<button class="login-cancel" onclick="closeLogin()">Cancelar</button>
<div class="login-note">Acceso restringido. Capa de cortesía para presentación, no un sistema de seguridad.</div>
</div></div>
<script id="deck-injector-js" is:inline>
let _pendingDeck=null;
function lockScroll(on){document.body.style.overflow=on?'hidden':'';}
function openDeck(w){document.getElementById(w==='mun'?'ovMun':'ovInv').classList.add('open');lockScroll(true);}
function closeDeck(w){document.getElementById(w==='mun'?'ovMun':'ovInv').classList.remove('open');lockScroll(false);}
function openLogin(which){_pendingDeck=which;var s=document.getElementById('loginSub');if(s)s.textContent='Acceso · '+(which==='inv'?'Presentación Inversionistas':'Presentación Clientes');document.getElementById('lerr').textContent='';document.getElementById('loginGate').classList.add('open');lockScroll(true);setTimeout(function(){document.getElementById('luser').focus();},50);}
function closeLogin(){document.getElementById('loginGate').classList.remove('open');lockScroll(false);document.getElementById('luser').value='';document.getElementById('lpass').value='';_pendingDeck=null;}
function tryLogin(){var u=document.getElementById('luser').value.trim();var p=document.getElementById('lpass').value;var btn=document.querySelector('#loginGate .login-btn');document.getElementById('lerr').textContent='';if(btn)btn.disabled=true;fetch('/api/deck-auth',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({user:u,pass:p})}).then(function(r){return r.json();}).then(function(d){if(d.ok){document.getElementById('loginGate').classList.remove('open');lockScroll(false);if(_pendingDeck==='inv'){var ifr=document.getElementById('ifInv');if(!ifr.getAttribute('src'))ifr.setAttribute('src','/decks/inversionistas.html');document.getElementById('ovInv').classList.add('open');}else{var ifrM=document.getElementById('ifMun');if(!ifrM.getAttribute('src'))ifrM.setAttribute('src','/decks/clientes.html');document.getElementById('ovMun').classList.add('open');}document.getElementById('luser').value='';document.getElementById('lpass').value='';_pendingDeck=null;}else{document.getElementById('lerr').textContent='Credenciales incorrectas.';}}).catch(function(){document.getElementById('lerr').textContent='Error de conexión. Intente nuevamente.';}).finally(function(){if(btn)btn.disabled=false;});}
document.addEventListener('keydown',function(e){if(e.key==='Escape'){if(document.getElementById('ovMun').classList.contains('open'))closeDeck('mun');if(document.getElementById('ovInv').classList.contains('open'))closeDeck('inv');if(document.getElementById('loginGate').classList.contains('open'))closeLogin();}});
</script>
</Layout>
