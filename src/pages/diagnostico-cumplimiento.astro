---
import DiagnosticoLeadForm from '../components/DiagnosticoLeadForm.astro';
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>MunIA — Diagnóstico de Cumplimiento Normativo Municipal</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20viewBox%3D%220%200%20100%20100%22%3E%3Crect%20width%3D%22100%22%20height%3D%22100%22%20rx%3D%2224%22%20fill%3D%22%231B9BFE%22/%3E%3Cg%20fill%3D%22none%22%20stroke%3D%22%23fff%22%20stroke-width%3D%225%22%20stroke-linejoin%3D%22round%22%20stroke-linecap%3D%22round%22%3E%3Ccircle%20cx%3D%2250%22%20cy%3D%2216%22%20r%3D%223.4%22%20stroke-width%3D%223.4%22/%3E%3Cline%20x1%3D%2250%22%20y1%3D%2219.4%22%20x2%3D%2250%22%20y2%3D%2229%22/%3E%3Cpath%20d%3D%22M22%2047%20L50%2028%20L78%2047%22%20stroke-width%3D%225.5%22/%3E%3Cline%20x1%3D%2220%22%20y1%3D%2252%22%20x2%3D%2280%22%20y2%3D%2252%22%20stroke-width%3D%226.5%22/%3E%3C/g%3E%3Cg%20fill%3D%22none%22%20stroke%3D%22%23fff%22%20stroke-width%3D%225%22%20stroke-linejoin%3D%22round%22%3E%3Crect%20x%3D%2227%22%20y%3D%2255%22%20width%3D%2246%22%20height%3D%2230%22%20rx%3D%222%22/%3E%3C/g%3E%3Cg%20fill%3D%22%23fff%22%3E%3Crect%20x%3D%2230%22%20y%3D%2263%22%20width%3D%226%22%20height%3D%2222%22%20rx%3D%221%22/%3E%3Crect%20x%3D%2247%22%20y%3D%2263%22%20width%3D%226%22%20height%3D%2222%22%20rx%3D%221%22/%3E%3Crect%20x%3D%2264%22%20y%3D%2263%22%20width%3D%226%22%20height%3D%2222%22%20rx%3D%221%22/%3E%3C/g%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style is:global>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --teal:#2196F3;--teal-dark:#1565C0;--teal-light:#42A5F5;--teal-pale:#E3F2FD;
  --bg1:#080B12;--bg2:#0D1117;--bg3:#111827;
  --text:#F0F4FF;--muted:#8B9DC3;--border:#1E2D4A;
  --white:#fff;--warn:#F59E0B;--ok:#34D399;--bad:#F87171;
}
html{scroll-behavior:smooth}
body{background:var(--bg1);color:var(--text);font-family:'Space Grotesk',sans-serif;line-height:1.6;-webkit-font-smoothing:antialiased}
.wrap{max-width:860px;margin:0 auto;padding:2.5rem 1.5rem 5rem}

/* BACK LINK */
.back-link{display:inline-flex;align-items:center;gap:8px;color:var(--muted);font-size:13px;text-decoration:none;margin-bottom:1.5rem;transition:.2s;font-family:'DM Mono',monospace;letter-spacing:.5px}
.back-link:hover{color:var(--teal)}
.back-link svg{width:16px;height:16px}

/* HEADER */
.hd{position:relative;overflow:hidden;border-radius:16px;background:var(--bg2);border:0.5px solid var(--border);padding:2.5rem 2rem;margin-bottom:2rem}
.hd::before{content:'';position:absolute;inset:0;background-image:radial-gradient(circle,rgba(33,150,243,.08) 1px,transparent 1px);background-size:32px 32px;opacity:.6;pointer-events:none}
.hd::after{content:'';position:absolute;right:-80px;top:-80px;width:360px;height:360px;background:radial-gradient(ellipse,rgba(33,150,243,.07),transparent 70%);pointer-events:none}
.badge{display:inline-flex;align-items:center;gap:7px;background:rgba(33,150,243,.1);color:var(--teal-light);border:0.5px solid rgba(33,150,243,.3);border-radius:20px;padding:5px 15px;font-size:10.5px;letter-spacing:2px;text-transform:uppercase;margin-bottom:1.25rem;position:relative;font-weight:500}
.badge::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--teal);display:block;animation:pulse 2.4s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
.wm{display:flex;align-items:baseline;font-size:24px;font-weight:700;letter-spacing:-.5px;position:relative;margin-bottom:1.5rem}
.wm .mun{color:var(--teal)}.wm .ia{color:var(--white)}
.hd h1{font-size:34px;font-weight:700;line-height:1.12;letter-spacing:-1px;position:relative;margin-bottom:.75rem}
.hd h1 .ac{color:var(--teal)}
.hd p{font-size:14.5px;color:var(--muted);max-width:560px;line-height:1.7;position:relative}
.hd .meta{font-family:'DM Mono',monospace;font-size:10.5px;color:var(--muted);letter-spacing:1.5px;margin-top:1.5rem;position:relative;padding-top:1.25rem;border-top:0.5px solid var(--border)}

/* PROGRESS BAR */
.steps-nav{display:flex;gap:8px;margin-bottom:1.75rem}
.step-pill{flex:1;background:var(--bg2);border:0.5px solid var(--border);border-radius:10px;padding:.7rem .9rem;display:flex;align-items:center;gap:10px;transition:.3s;opacity:.5}
.step-pill.active{opacity:1;border-color:rgba(33,150,243,.4);background:rgba(33,150,243,.06)}
.step-pill.done{opacity:1}
.step-pill .sp-n{width:24px;height:24px;border-radius:50%;border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:var(--muted);flex-shrink:0;font-family:'DM Mono',monospace}
.step-pill.active .sp-n{border-color:var(--teal);color:var(--teal)}
.step-pill.done .sp-n{border-color:var(--ok);background:rgba(52,211,153,.12);color:var(--ok)}
.step-pill .sp-t{font-size:12px;color:var(--muted);line-height:1.25}
.step-pill.active .sp-t{color:var(--text)}
@media(max-width:640px){.step-pill .sp-t{display:none}.steps-nav{gap:6px}}

/* LAW SECTION */
.law-block{background:var(--bg2);border:0.5px solid var(--border);border-radius:14px;padding:1.75rem;margin-bottom:1.25rem;display:none}
.law-block.show{display:block;animation:fade .4s}
@keyframes fade{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.law-head{display:flex;align-items:flex-start;gap:14px;margin-bottom:.5rem}
.law-code{font-family:'DM Mono',monospace;font-size:11px;font-weight:500;color:var(--teal-light);background:rgba(33,150,243,.1);border:0.5px solid rgba(33,150,243,.25);border-radius:7px;padding:5px 11px;letter-spacing:1px;flex-shrink:0;white-space:nowrap}
.law-head h2{font-size:20px;font-weight:600;line-height:1.25;letter-spacing:-.3px}
.law-desc{font-size:13.5px;color:var(--muted);line-height:1.7;margin:.5rem 0 1.5rem;padding-bottom:1.25rem;border-bottom:0.5px solid var(--border)}
.law-desc .dl{color:var(--warn);font-weight:500}

/* QUESTIONS */
.q{margin-bottom:1rem;padding-bottom:1rem;border-bottom:0.5px solid rgba(30,45,74,.5)}
.q:last-of-type{border-bottom:0;margin-bottom:.5rem;padding-bottom:0}
.q-txt{font-size:14.5px;color:var(--text);line-height:1.5;margin-bottom:.75rem;display:flex;gap:9px;align-items:flex-start}
.q-txt .qi{color:var(--teal);flex-shrink:0;margin-top:2px}
.q-txt .qi svg{width:17px;height:17px;display:block}
.opts{display:flex;gap:8px;flex-wrap:wrap;padding-left:26px}
.opt{cursor:pointer;border:0.5px solid var(--border);background:var(--bg3);border-radius:9px;padding:.55rem 1.1rem;font-size:13px;color:var(--muted);transition:.2s;font-family:inherit;user-select:none}
.opt:hover{border-color:rgba(33,150,243,.4);color:var(--text)}
.opt.sel-yes{border-color:var(--ok);background:rgba(52,211,153,.12);color:var(--ok)}
.opt.sel-partial{border-color:var(--warn);background:rgba(245,158,11,.12);color:var(--warn)}
.opt.sel-no{border-color:var(--bad);background:rgba(248,113,113,.12);color:var(--bad)}

/* NAV BUTTONS */
.nav-row{display:flex;justify-content:space-between;gap:12px;margin-top:1.5rem}
.btn{font-family:inherit;font-size:14px;font-weight:500;border-radius:10px;padding:.8rem 1.6rem;cursor:pointer;transition:.2s;border:0.5px solid var(--border);display:inline-flex;align-items:center;gap:8px}
.btn svg{width:16px;height:16px}
.btn-ghost{background:transparent;color:var(--muted)}
.btn-ghost:hover{color:var(--text);border-color:var(--teal)}
.btn-p{background:var(--teal);color:#04121f;border-color:var(--teal);font-weight:600}
.btn-p:hover{background:var(--teal-light);box-shadow:0 6px 24px rgba(33,150,243,.25)}
.btn-p:disabled{opacity:.35;cursor:not-allowed;box-shadow:none}
.warn-incomplete{font-size:12px;color:var(--warn);text-align:right;margin-top:.6rem;display:none;font-family:'DM Mono',monospace}

/* RESULTS */
.results{display:none}
.results.show{display:block;animation:fade .5s}
.res-hero{background:var(--bg2);border:0.5px solid var(--border);border-radius:16px;padding:2rem;margin-bottom:1.25rem;position:relative;overflow:hidden}
.res-hero::after{content:'';position:absolute;right:-60px;top:-60px;width:300px;height:300px;background:radial-gradient(ellipse,rgba(33,150,243,.08),transparent 70%);pointer-events:none}
.res-hero .rl{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--teal-light);margin-bottom:1rem;position:relative}
.gauge-wrap{display:flex;align-items:center;gap:2rem;position:relative}
@media(max-width:560px){.gauge-wrap{flex-direction:column;gap:1.25rem;text-align:center}}
.gauge{position:relative;width:150px;height:150px;flex-shrink:0}
.gauge svg{transform:rotate(-90deg)}
.gauge-num{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.gauge-num .gv{font-size:40px;font-weight:700;letter-spacing:-1px;line-height:1}
.gauge-num .gl{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-top:3px}
.res-verdict h3{font-size:22px;font-weight:600;line-height:1.25;margin-bottom:.5rem}
.res-verdict p{font-size:14px;color:var(--muted);line-height:1.7}

/* PER-LAW CARDS */
.lawres{background:var(--bg2);border:0.5px solid var(--border);border-radius:14px;padding:1.5rem;margin-bottom:1rem}
.lawres-top{display:flex;align-items:center;gap:12px;margin-bottom:1rem}
.lawres-code{font-family:'DM Mono',monospace;font-size:11px;color:var(--teal-light);background:rgba(33,150,243,.1);border-radius:6px;padding:4px 9px;letter-spacing:1px}
.lawres-top h4{font-size:15px;font-weight:600;flex:1;line-height:1.3}
.lawres-pct{font-size:22px;font-weight:700;font-family:'DM Mono',monospace}
.bar{height:7px;border-radius:4px;background:var(--bg3);overflow:hidden;margin-bottom:1.25rem}
.bar-fill{height:100%;border-radius:4px;transition:width 1s cubic-bezier(.4,0,.2,1)}
.gaps-title{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:.7rem}
.gap{display:flex;gap:11px;align-items:flex-start;margin-bottom:.85rem;font-size:13.5px;line-height:1.55}
.gap:last-child{margin-bottom:0}
.gap-ico{flex-shrink:0;width:18px;height:18px;margin-top:1px}
.gap-ico.bad{color:var(--bad)}.gap-ico.partial{color:var(--warn)}
.gap-body .gt{color:var(--text)}
.gap-body .gm{color:var(--teal-light);font-size:12.5px;margin-top:2px;display:flex;gap:6px;align-items:flex-start}
.gap-body .gm svg{width:13px;height:13px;flex-shrink:0;margin-top:3px}
.allgood{display:flex;gap:10px;align-items:center;font-size:13.5px;color:var(--ok)}
.allgood svg{width:18px;height:18px}

/* CTA */
.cta{background:linear-gradient(135deg,rgba(33,150,243,.1),rgba(33,150,243,.03));border:0.5px solid rgba(33,150,243,.3);border-radius:16px;padding:2rem;text-align:center;margin-top:1.5rem}
.cta h3{font-size:21px;font-weight:600;margin-bottom:.6rem;letter-spacing:-.3px}
.cta p{font-size:14px;color:var(--muted);max-width:480px;margin:0 auto 1.5rem;line-height:1.7}
.cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}

.foot{text-align:center;font-family:'DM Mono',monospace;font-size:10.5px;color:var(--muted);letter-spacing:1px;margin-top:2.5rem;line-height:1.8}
.disc{font-size:11px;color:var(--muted);text-align:center;max-width:560px;margin:1.5rem auto 0;line-height:1.6;opacity:.7}

</style>
</head>
<body>
<div class="wrap">

  <a href="/" class="back-link">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    Volver al sitio
  </a>

  <!-- HEADER -->
  <div class="hd">
    <div class="badge">Diagnóstico de cumplimiento</div>
    <div class="wm"><span class="mun">Mun</span><span class="ia">IA</span></div>
    <h1>¿Está su municipio preparado para <span class="ac">2027</span>?</h1>
    <p>Tres leyes obligan a los 345 municipios de Chile a digitalizar su atención ciudadana, proteger los datos de sus vecinos y asegurar sus sistemas. Responda 12 preguntas y reciba un diagnóstico claro de dónde está parado y qué le falta cerrar.</p>
    <div class="meta">12 PREGUNTAS · 3 LEYES · ~3 MINUTOS · RESULTADO INMEDIATO</div>
  </div>

  <!-- STEP NAV -->
  <div class="steps-nav">
    <div class="step-pill active" data-pill="0"><div class="sp-n">1</div><div class="sp-t">Ley 21.180<br>Transformación Digital</div></div>
    <div class="step-pill" data-pill="1"><div class="sp-n">2</div><div class="sp-t">Ley 21.719<br>Protección de Datos</div></div>
    <div class="step-pill" data-pill="2"><div class="sp-n">3</div><div class="sp-t">Ley 21.663<br>Ciberseguridad</div></div>
  </div>

  <!-- LAW 1 -->
  <div class="law-block show" data-block="0">
    <div class="law-head">
      <span class="law-code">LEY 21.180</span>
      <h2>Transformación Digital del Estado</h2>
    </div>
    <p class="law-desc">Obliga a tramitar todo procedimiento administrativo en formato electrónico, con expediente interoperable y trazable. <span class="dl">Plazo perentorio: 31 de diciembre de 2027.</span></p>
    <div class="q-container"></div>
    <div class="nav-row">
      <span></span>
      <button class="btn btn-p" data-next="0">Continuar <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></button>
    </div>
    <div class="warn-incomplete">Responda todas las preguntas para continuar</div>
  </div>

  <!-- LAW 2 -->
  <div class="law-block" data-block="1">
    <div class="law-head">
      <span class="law-code">LEY 21.719</span>
      <h2>Protección de Datos Personales</h2>
    </div>
    <p class="law-desc">Estándar equivalente al GDPR europeo. Exige consentimiento explícito y capacidad real de responder a los derechos del vecino sobre sus datos. <span class="dl">Vigencia plena: 1 de diciembre de 2026.</span></p>
    <div class="q-container"></div>
    <div class="nav-row">
      <button class="btn btn-ghost" data-back="1"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg> Atrás</button>
      <button class="btn btn-p" data-next="1">Continuar <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></button>
    </div>
    <div class="warn-incomplete">Responda todas las preguntas para continuar</div>
  </div>

  <!-- LAW 3 -->
  <div class="law-block" data-block="2">
    <div class="law-head">
      <span class="law-code">LEY 21.663</span>
      <h2>Marco de Ciberseguridad</h2>
    </div>
    <p class="law-desc">Categoriza a los municipios como Operadores de Importancia Vital. Exige controles auditables y reporte de incidentes a la ANCI. <span class="dl">Vigente desde abril de 2024, con fiscalización progresiva.</span></p>
    <div class="q-container"></div>
    <div class="nav-row">
      <button class="btn btn-ghost" data-back="2"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg> Atrás</button>
      <button class="btn btn-p" data-next="2">Ver mi diagnóstico <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></button>
    </div>
    <div class="warn-incomplete">Responda todas las preguntas para continuar</div>
  </div>

  <DiagnosticoLeadForm />

  <!-- RESULTS -->
  <div class="results" id="results">
    <div class="res-hero">
      <div class="rl">Resultado del diagnóstico</div>
      <div class="gauge-wrap">
        <div class="gauge">
          <svg width="150" height="150" viewBox="0 0 150 150">
            <circle cx="75" cy="75" r="64" fill="none" stroke="#111827" stroke-width="11"/>
            <circle id="gaugeArc" cx="75" cy="75" r="64" fill="none" stroke="#2196F3" stroke-width="11" stroke-linecap="round" stroke-dasharray="402" stroke-dashoffset="402"/>
          </svg>
          <div class="gauge-num"><div class="gv" id="gaugeVal">0%</div><div class="gl">Global</div></div>
        </div>
        <div class="res-verdict">
          <h3 id="verdictTitle"></h3>
          <p id="verdictText"></p>
        </div>
      </div>
    </div>
    <div id="lawResults"></div>

    <div class="cta">
      <h3>De la brecha al cumplimiento, sin un proyecto adicional</h3>
      <p>MunIA cierra estas brechas de forma operacional: cada solicitud genera un expediente electrónico trazable, el consentimiento queda registrado, y los controles de ciberseguridad vienen activos desde el día uno. Agende una demostración con sus trámites reales.</p>
      <div class="cta-btns">
        <a href="#" class="btn btn-p" id="ctaDemo">Agendar demostración</a>
        <button class="btn btn-ghost" id="ctaPrint"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg> Descargar reporte</button>
        <button class="btn btn-ghost" id="ctaRestart"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg> Repetir</button>
      </div>
    </div>

    <p class="disc">Este diagnóstico es una herramienta orientativa de autoevaluación basada en los requisitos centrales de las leyes 21.180, 21.719 y 21.663. No constituye asesoría legal ni una certificación de cumplimiento. El alcance exacto de cada obligación debe verificarse con el marco normativo vigente y asesoría especializada.</p>
  </div>

  <div class="foot">ALTKIMIA · MunIA — Atención ciudadana con IA<br>Leyes 21.180 / 21.719 / 21.663 · SUBDERE · ANCI</div>

</div>

<script is:inline>
const LAWS = [
  {
    code:"21.180", name:"Transformación Digital del Estado",
    questions:[
      {q:"¿Sus vecinos pueden iniciar y seguir trámites en formato 100% electrónico, sin papel obligatorio?",
       gap:"Trámites aún dependen de papel o presencialidad obligatoria.",
       munia:"Portal ciudadano 24/7: el vecino inicia y sigue cada trámite en línea, con código QR de seguimiento."},
      {q:"¿Cada solicitud genera un expediente electrónico con historial completo de quién hizo qué y cuándo?",
       gap:"No existe expediente digital trazable por caso.",
       munia:"Cada caso genera un expediente con bitácora automática de todas las acciones y responsables."},
      {q:"¿El municipio notifica resoluciones por medios digitales con validez legal (Domicilio Digital Único)?",
       gap:"Las notificaciones siguen siendo en papel o sin validez legal digital.",
       munia:"Integración con Registro Civil y FES/FEA para notificar al Domicilio Digital Único del vecino."},
      {q:"¿Los vecinos se autentican con ClaveÚnica al realizar trámites con el municipio?",
       gap:"No hay autenticación con la identidad digital oficial del Estado.",
       munia:"ClaveÚnica nativa: identidad verificada del Registro Civil, sin cuentas paralelas."}
    ]
  },
  {
    code:"21.719", name:"Protección de Datos Personales",
    questions:[
      {q:"¿Registra el consentimiento explícito del vecino cada vez que recopila sus datos personales?",
       gap:"No se registra consentimiento explícito y auditable.",
       munia:"Registro de consentimiento en cada solicitud, con fecha y trazabilidad exportable."},
      {q:"¿Puede un vecino solicitar acceso, corrección o eliminación de sus datos, y el municipio responder con evidencia?",
       gap:"No existe mecanismo operativo para ejercer los derechos del titular.",
       munia:"El vecino accede a sus propios datos y solicita corrección o eliminación desde el portal."},
      {q:"¿Los datos personales están cifrados en tránsito y en reposo?",
       gap:"Datos sin cifrado o sin garantía técnica de protección.",
       munia:"Cifrado en tránsito y en reposo como estándar de diseño, no como añadido."},
      {q:"¿Tiene definido por escrito quién es responsable y quién encargado del tratamiento de datos?",
       gap:"Sin contrato de tratamiento de datos ni roles definidos.",
       munia:"Contrato de tratamiento de datos incluido: municipio responsable, MunIA encargado."}
    ]
  },
  {
    code:"21.663", name:"Marco de Ciberseguridad",
    questions:[
      {q:"¿Los funcionarios con roles críticos usan autenticación de doble factor (MFA)?",
       gap:"Acceso a sistemas sensibles solo con contraseña.",
       munia:"MFA obligatorio para administradores y jefaturas desde el primer ingreso."},
      {q:"¿Existe un registro de auditoría que deje constancia de cada acceso y modificación en sus sistemas?",
       gap:"Sin log de auditoría consultable ni exportable.",
       munia:"Log de auditoría completo: quién accedió, qué modificó y cuándo, exportable por el administrador."},
      {q:"¿Tiene un protocolo para detectar incidentes de seguridad y reportarlos a la ANCI cuando corresponde?",
       gap:"Sin protocolo de gestión ni reporte de incidentes a la ANCI.",
       munia:"Gestión de incidentes con alerta al responsable y soporte para notificar a la ANCI."},
      {q:"¿Las sesiones inactivas se cierran automáticamente para evitar accesos no autorizados?",
       gap:"Sesiones quedan abiertas en equipos desatendidos.",
       munia:"Cierre automático de sesiones inactivas como control por defecto."}
    ]
  }
];

const CALENDLY_URL = "#";

const answers = {};
let current = 0;

const qIcon = '<span class="qi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></span>';
document.querySelectorAll('.law-block').forEach(function(block, li) {
  var cont = block.querySelector('.q-container');
  LAWS[li].questions.forEach(function(item, qi) {
    var key = li + '-' + qi;
    var q = document.createElement('div');
    q.className = 'q';
    q.innerHTML = '<div class="q-txt">' + qIcon + '<span>' + item.q + '</span></div>' +
      '<div class="opts" data-key="' + key + '">' +
      '<button class="opt" data-v="yes">Sí</button>' +
      '<button class="opt" data-v="partial">Parcialmente</button>' +
      '<button class="opt" data-v="no">No</button>' +
      '</div>';
    cont.appendChild(q);
  });
});

document.querySelectorAll('.opts').forEach(function(group) {
  group.querySelectorAll('.opt').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var key = group.dataset.key, v = btn.dataset.v;
      answers[key] = v;
      group.querySelectorAll('.opt').forEach(function(b) { b.className = 'opt'; });
      btn.className = 'opt sel-' + v;
      checkComplete(parseInt(key.split('-')[0]));
    });
  });
});

function blockComplete(li) {
  return LAWS[li].questions.every(function(_, qi) { return answers[li + '-' + qi]; });
}
function checkComplete(li) {
  var block = document.querySelector('.law-block[data-block="' + li + '"]');
  var btn = block.querySelector('.btn-p');
  var warn = block.querySelector('.warn-incomplete');
  if (blockComplete(li)) { btn.disabled = false; warn.style.display = 'none'; }
  else { btn.disabled = true; }
}
document.querySelectorAll('.btn-p[data-next]').forEach(function(b) { b.disabled = true; });

function goTo(idx) {
  current = idx;
  document.querySelectorAll('.law-block').forEach(function(b, i) { b.classList.toggle('show', i === idx); });
  document.querySelectorAll('.step-pill').forEach(function(p, i) {
    p.classList.toggle('active', i === idx);
    p.classList.toggle('done', i < idx);
  });
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
document.querySelectorAll('[data-next]').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var li = parseInt(btn.dataset.next);
    if (!blockComplete(li)) {
      btn.closest('.law-block').querySelector('.warn-incomplete').style.display = 'block';
      return;
    }
    if (li < 2) goTo(li + 1);
    else showLeadForm();
  });
});
document.querySelectorAll('[data-back]').forEach(function(btn) {
  btn.addEventListener('click', function() { goTo(parseInt(btn.dataset.back) - 1); });
});

function colorFor(p) { return p >= 80 ? '#34D399' : p >= 50 ? '#F59E0B' : '#F87171'; }

function lawScore(li) {
  var s = 0;
  LAWS[li].questions.forEach(function(_, qi) {
    var a = answers[li + '-' + qi];
    s += a === 'yes' ? 1 : a === 'partial' ? 0.5 : 0;
  });
  return Math.round(s / LAWS[li].questions.length * 100);
}

function showResults() {
  document.querySelectorAll('.law-block').forEach(function(b) { b.classList.remove('show'); });
  document.querySelector('.steps-nav').style.display = 'none';
  var res = document.getElementById('results');
  res.classList.add('show');

  var scores = [0, 1, 2].map(lawScore);
  var global = Math.round(scores.reduce(function(a, b) { return a + b; }, 0) / 3);

  var arc = document.getElementById('gaugeArc');
  var circ = 402;
  arc.style.stroke = colorFor(global);
  setTimeout(function() { arc.style.strokeDashoffset = circ - (circ * global / 100); }, 100);

  var cv = 0;
  var gv = document.getElementById('gaugeVal');
  var iv = setInterval(function() {
    cv += 2;
    if (cv >= global) { cv = global; clearInterval(iv); }
    gv.textContent = cv + '%';
  }, 20);
  gv.style.color = colorFor(global);

  var vt, vp;
  if (global >= 80) {
    vt = "Municipio adelantado";
    vp = "Su municipio cubre la mayor parte de las exigencias. Quedan ajustes puntuales para llegar blindado a 2027 — y para demostrarlo con evidencia.";
  } else if (global >= 50) {
    vt = "Avance parcial, brechas activas";
    vp = "Hay base construida, pero quedan brechas que dejan al municipio expuesto. Actuar ahora evita comprar bajo presión cuando el plazo apriete.";
  } else {
    vt = "Exposición alta frente a 2027";
    vp = "El municipio tiene brechas críticas en las tres leyes. La buena noticia: se cierran de forma operacional, sin un proyecto monumental, si se empieza a tiempo.";
  }
  document.getElementById('verdictTitle').textContent = vt;
  document.getElementById('verdictText').textContent = vp;

  var wrap = document.getElementById('lawResults');
  wrap.innerHTML = '';
  LAWS.forEach(function(law, li) {
    var p = scores[li];
    var col = colorFor(p);
    var gaps = '';
    var hasGap = false;
    law.questions.forEach(function(item, qi) {
      var a = answers[li + '-' + qi];
      if (a === 'no' || a === 'partial') {
        hasGap = true;
        var cls = a === 'no' ? 'bad' : 'partial';
        var ico = a === 'no'
          ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>'
          : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';
        gaps += '<div class="gap"><span class="gap-ico ' + cls + '">' + ico + '</span><div class="gap-body"><div class="gt">' + item.gap + '</div>' +
          '<div class="gm"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg><span>MunIA: ' + item.munia + '</span></div></div></div>';
      }
    });
    if (!hasGap) {
      gaps = '<div class="allgood"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Sin brechas detectadas en esta ley.</div>';
    }
    var card = document.createElement('div');
    card.className = 'lawres';
    card.innerHTML =
      '<div class="lawres-top"><span class="lawres-code">LEY ' + law.code + '</span><h4>' + law.name + '</h4>' +
      '<span class="lawres-pct" style="color:' + col + '">' + p + '%</span></div>' +
      '<div class="bar"><div class="bar-fill" style="width:0;background:' + col + '"></div></div>' +
      (hasGap ? '<div class="gaps-title">Brechas a cerrar</div>' : '') + gaps;
    wrap.appendChild(card);
    setTimeout(function() { card.querySelector('.bar-fill').style.width = p + '%'; }, 200 + li * 150);
  });

  document.getElementById('ctaDemo').href = CALENDLY_URL;
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

document.getElementById('ctaRestart').addEventListener('click', function() {
  for (var k in answers) delete answers[k];
  document.querySelectorAll('.opt').forEach(function(b) { b.className = 'opt'; });
  document.querySelectorAll('.btn-p[data-next]').forEach(function(b) { b.disabled = true; });
  document.getElementById('results').classList.remove('show');
  document.getElementById('leadForm').classList.remove('show');
  document.querySelector('.steps-nav').style.display = 'flex';
  goTo(0);
});
document.getElementById('ctaPrint').addEventListener('click', function() { window.print(); });

// ---- LEAD FORM ----
function showLeadForm() {
  document.querySelectorAll('.law-block').forEach(function(b) { b.classList.remove('show'); });
  document.querySelector('.steps-nav').style.display = 'none';
  document.getElementById('leadForm').classList.add('show');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
document.addEventListener('lead-form-submitted', function() { showResults(); });
</script>
</body>
</html>
